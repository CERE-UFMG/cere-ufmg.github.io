---
interface Props {
  // 'full' exibe descrição longa e endereço completo (páginas Início e Sobre);
  // 'short' exibe a versão resumida usada nas demais páginas.
  brand?: 'full' | 'short';
  // Apenas a página inicial exibe "Todos os direitos reservados."
  allRights?: boolean;
}

const { brand = 'short', allRights = false } = Astro.props;
---
<footer class="site-footer">
  <div class="footer-main">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="site-logo" style="gap:.6rem;">
          <div class="logo-accent" style="height:36px;"></div>
          <div class="logo-text">
            <span class="logo-cere">CERE</span>
            <span class="logo-name" data-lang="pt">Centro de Estudos em Real Estate</span>
            <span class="logo-name" data-lang="en">Real Estate Studies Center</span>
            <span class="logo-univ">UFMG · FACE</span>
          </div>
        </div>
        {brand === 'full' ? (
          <>
            <p data-lang="pt">Centro de referência em estudos de real estate da Faculdade de Ciências Econômicas da UFMG.</p>
            <p data-lang="en">Reference center for real estate studies at UFMG's Faculty of Economic Sciences.</p>
            <address data-lang="pt">Av. Antônio Carlos, 6627 — Pampulha<br>Belo Horizonte, MG — CEP 31270-901<br>renanpa@cedeplar.ufmg.br</address>
            <address data-lang="en">Av. Antônio Carlos, 6627 — Pampulha<br>Belo Horizonte, MG — ZIP 31270-901<br>renanpa@cedeplar.ufmg.br</address>
          </>
        ) : (
          <>
            <p data-lang="pt">Centro de referência em estudos de real estate da UFMG.</p>
            <p data-lang="en">Reference center for real estate studies at UFMG.</p>
            <address>renanpa@cedeplar.ufmg.br</address>
          </>
        )}
        <div class="social-links">
          <a href="#" class="social-link" aria-label="LinkedIn">in</a>
          <a href="#" class="social-link" aria-label="Instagram">ig</a>
          <a href="#" class="social-link" aria-label="YouTube">yt</a>
        </div>
      </div>

      <slot />
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      {allRights ? (
        <>
          <span data-lang="pt">© 2025 CERE — Centro de Estudos em Real Estate | UFMG. Todos os direitos reservados.</span>
          <span data-lang="en">© 2025 CERE — Real Estate Studies Center | UFMG. All rights reserved.</span>
        </>
      ) : (
        <>
          <span data-lang="pt">© 2025 CERE — Centro de Estudos em Real Estate | UFMG.</span>
          <span data-lang="en">© 2025 CERE — Real Estate Studies Center | UFMG.</span>
        </>
      )}
      <a href="https://face.ufmg.br" target="_blank" rel="noopener">face.ufmg.br</a>
    </div>
  </div>
</footer>
