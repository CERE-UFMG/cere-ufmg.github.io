---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout
  title="Sobre nós — CERE | UFMG"
  description="Missão, equipe e contato do Centro de Estudos em Real Estate da UFMG."
>

  <PageHero
    crumbs={[{ pt: 'Sobre nós', en: 'About us' }]}
    titlePt="Sobre nós"
    titleEn="About us"
    subtitlePt="Conheça nossa missão, nossa equipe e como entrar em contato."
    subtitleEn="Learn about our mission, our team, and how to get in touch."
  />

  <!-- MISSÃO -->
  <section class="section" id="missao">
    <div class="container">
      <div class="section-header left">
        <p class="eyebrow" data-lang="pt">Missão</p>
        <p class="eyebrow" data-lang="en">Mission</p>
        <h2 class="section-title" data-lang="pt">Nossa missão e valores</h2>
        <h2 class="section-title" data-lang="en">Our mission and values</h2>
        <div class="divider"></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;">
        <div class="prose">
          <p data-lang="pt">O <strong>Centro de Estudos em Real Estate (CERE)</strong> da Faculdade de Ciências Econômicas da UFMG é um núcleo acadêmico dedicado à pesquisa, ao ensino e à extensão no campo do real estate — termo que compreende o mercado imobiliário e as atividades de incorporação, construção, financiamento e gestão de ativos imobiliários.</p>
          <p data-lang="en">The <strong>Real Estate Studies Center (CERE)</strong> at UFMG's Faculty of Economic Sciences is an academic hub dedicated to research, teaching, and outreach in the field of real estate — encompassing the real estate market and activities of development, construction, financing, and property asset management.</p>
          <p data-lang="pt">Fundado com o objetivo de suprir a lacuna de conhecimento científico aplicado ao setor imobiliário no Brasil, o CERE atua na interface entre a academia, o setor privado e o poder público, gerando análises, indicadores e propostas que contribuem para o desenvolvimento sustentável e transparente do setor.</p>
          <p data-lang="en">Founded to fill the gap in applied scientific knowledge for the real estate sector in Brazil, CERE operates at the intersection of academia, the private sector, and government, generating analyses, indicators, and proposals that contribute to the sustainable and transparent development of the sector.</p>
          <h2 data-lang="pt">Nossa missão</h2>
          <h2 data-lang="en">Our mission</h2>
          <p data-lang="pt">Produzir e disseminar conhecimento de excelência em real estate, formando profissionais e líderes comprometidos com o desenvolvimento do setor imobiliário e com o bem-estar social.</p>
          <p data-lang="en">To produce and disseminate knowledge of excellence in real estate, training professionals and leaders committed to the development of the real estate sector and social well-being.</p>
          <h2 data-lang="pt">Nossa visão</h2>
          <h2 data-lang="en">Our vision</h2>
          <p data-lang="pt">Ser reconhecido como o principal centro de referência em estudos de real estate do Brasil, com projeção internacional e impacto real no desenvolvimento do setor imobiliário nacional.</p>
          <p data-lang="en">To be recognized as Brazil's leading reference center for real estate studies, with international projection and real impact on the development of the national real estate sector.</p>
        </div>
        <div>
          <div style="background:var(--gray-50);border:1px solid var(--gray-200);border-radius:var(--radius);padding:2rem;margin-bottom:1.5rem;">
            <h3 style="color:var(--navy);font-weight:700;margin-bottom:1rem;font-size:1rem;" data-lang="pt">Nossos valores</h3>
            <h3 style="color:var(--navy);font-weight:700;margin-bottom:1rem;font-size:1rem;" data-lang="en">Our values</h3>
            <ul style="list-style:none;">
              <li style="padding:.6rem 0;border-bottom:1px solid var(--gray-200);display:flex;gap:.75rem;align-items:start;">
                <span style="color:var(--red);font-weight:700;flex-shrink:0;">→</span>
                <span data-lang="pt"><strong>Rigor científico</strong> — Pesquisa baseada em evidências e metodologias robustas.</span>
                <span data-lang="en"><strong>Scientific rigor</strong> — Evidence-based research using robust methodologies.</span>
              </li>
              <li style="padding:.6rem 0;border-bottom:1px solid var(--gray-200);display:flex;gap:.75rem;align-items:start;">
                <span style="color:var(--red);font-weight:700;flex-shrink:0;">→</span>
                <span data-lang="pt"><strong>Transparência</strong> — Dados e análises acessíveis à sociedade.</span>
                <span data-lang="en"><strong>Transparency</strong> — Data and analyses accessible to society.</span>
              </li>
              <li style="padding:.6rem 0;border-bottom:1px solid var(--gray-200);display:flex;gap:.75rem;align-items:start;">
                <span style="color:var(--red);font-weight:700;flex-shrink:0;">→</span>
                <span data-lang="pt"><strong>Inovação</strong> — Abordagens novas para questões complexas do setor.</span>
                <span data-lang="en"><strong>Innovation</strong> — New approaches to complex sector challenges.</span>
              </li>
              <li style="padding:.6rem 0;display:flex;gap:.75rem;align-items:start;">
                <span style="color:var(--red);font-weight:700;flex-shrink:0;">→</span>
                <span data-lang="pt"><strong>Impacto social</strong> — Conhecimento que contribui para melhores políticas habitacionais e urbanas.</span>
                <span data-lang="en"><strong>Social impact</strong> — Knowledge that contributes to better housing and urban policies.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PESSOAS -->
  <section class="section bg-light" id="pessoas">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow" data-lang="pt">Equipe</p>
        <p class="eyebrow" data-lang="en">Team</p>
        <h2 class="section-title" data-lang="pt">Nossa equipe</h2>
        <h2 class="section-title" data-lang="en">Our team</h2>
        <div class="divider"></div>
        <p class="section-sub" data-lang="pt">Professores, pesquisadores e colaboradores dedicados ao avanço do conhecimento em real estate.</p>
        <p class="section-sub" data-lang="en">Professors, researchers, and collaborators dedicated to advancing knowledge in real estate.</p>
      </div>

      <p class="eyebrow mb-2" data-lang="pt">Coordenação</p>
      <p class="eyebrow mb-2" data-lang="en">Leadership</p>
      <div class="team-grid mb-4">
        <div class="team-card">
          <div class="team-avatar"><img src="/img/equipe/renan-pereira-almeida.jpg" alt="Prof. Renan Pereira Almeida" loading="lazy"></div>
          <p class="team-name">Prof. Renan Pereira Almeida</p>
          <p class="team-role" data-lang="pt">Coordenador Geral — Cedeplar/FACE/UFMG e Latin American Real Estate Society</p>
          <p class="team-role" data-lang="en">General Coordinator — Cedeplar/FACE/UFMG and Latin American Real Estate Society</p>
          <p class="team-lattes"><a href="http://lattes.cnpq.br/2296006792863846" target="_blank" rel="noopener">Lattes</a> · <a href="https://somos.ufmg.br/professor/renan-pereira-almeida" target="_blank" rel="noopener">Perfil UFMG</a> · <a href="https://www.linkedin.com/in/renan-pereira-almeida-b3a50060/" target="_blank" rel="noopener">LinkedIn</a></p>
        </div>
      </div>

      <p class="eyebrow mb-2" data-lang="pt">Pesquisadores</p>
      <p class="eyebrow mb-2" data-lang="en">Researchers</p>
      <div class="team-grid">
        <div class="team-card">
          <div class="team-avatar"><img src="/img/equipe/anderson-tadeu-marques-cavalcante.jpg" alt="Prof. Anderson Tadeu Marques Cavalcante" loading="lazy"></div>
          <p class="team-name">Prof. Anderson Tadeu Marques Cavalcante</p>
          <p class="team-role" data-lang="pt">Vice-diretor FACE/UFMG — Cedeplar/FACE/UFMG</p>
          <p class="team-role" data-lang="en">Deputy Director, FACE/UFMG — Cedeplar/FACE/UFMG</p>
          <p class="team-lattes"><a href="http://lattes.cnpq.br/6409622356433401" target="_blank" rel="noopener">Lattes</a> · <a href="https://somos.ufmg.br/professor/anderson-tadeu-marques-cavalcante" target="_blank" rel="noopener">Perfil UFMG</a></p>
        </div>
        <div class="team-card">
          <div class="team-avatar"><img src="/img/equipe/fabricio-jose-missio.jpg" alt="Prof. Fabrício José Missio" loading="lazy" style="object-position:center 15%;"></div>
          <p class="team-name">Prof. Fabrício José Missio</p>
          <p class="team-role" data-lang="pt">Presidente da Fundação IPEAD — Cedeplar/FACE/UFMG</p>
          <p class="team-role" data-lang="en">President of Fundação IPEAD — Cedeplar/FACE/UFMG</p>
          <p class="team-lattes"><a href="http://lattes.cnpq.br/5047485742216555" target="_blank" rel="noopener">Lattes</a> · <a href="https://somos.ufmg.br/professor/fabricio-jose-missio" target="_blank" rel="noopener">Perfil UFMG</a></p>
        </div>
        <div class="team-card">
          <div class="team-avatar"><img src="/img/equipe/pedro-vasconcelos-maia-do-amaral.jpg" alt="Prof. Pedro Vasconcelos Maia do Amaral" loading="lazy" style="object-position:center 15%;"></div>
          <p class="team-name">Prof. Pedro Vasconcelos Maia do Amaral</p>
          <p class="team-role" data-lang="pt">Cedeplar/FACE/UFMG e University of Chicago</p>
          <p class="team-role" data-lang="en">Cedeplar/FACE/UFMG and University of Chicago</p>
          <p class="team-lattes"><a href="http://lattes.cnpq.br/9862252313257052" target="_blank" rel="noopener">Lattes</a> · <a href="https://somos.ufmg.br/professor/pedro-vasconcelos-maia-do-amaral" target="_blank" rel="noopener">Perfil UFMG</a></p>
        </div>
        <div class="team-card">
          <div class="team-avatar"><img src="/img/equipe/rafael-saulo-marques-ribeiro.jpg" alt="Prof. Rafael Saulo Marques Ribeiro" loading="lazy"></div>
          <p class="team-name">Prof. Rafael Saulo Marques Ribeiro</p>
          <p class="team-role" data-lang="pt">Cedeplar/FACE/UFMG, MADE/USP e University of Cambridge</p>
          <p class="team-role" data-lang="en">Cedeplar/FACE/UFMG, MADE/USP and University of Cambridge</p>
          <p class="team-lattes"><a href="http://lattes.cnpq.br/5949531548153118" target="_blank" rel="noopener">Lattes</a> · <a href="https://somos.ufmg.br/professor/rafael-saulo-marques-ribeiro" target="_blank" rel="noopener">Perfil UFMG</a></p>
        </div>
        <div class="team-card">
          <div class="team-avatar"><img src="/img/equipe/joao-bosco-moura-tonucci-filho.jpg" alt="Prof. João Bosco Moura Tonucci Filho" loading="lazy"></div>
          <p class="team-name">Prof. João Bosco Moura Tonucci Filho</p>
          <p class="team-role" data-lang="pt">Professor Adjunto de Economia Regional e Urbana — Cedeplar/FACE/UFMG</p>
          <p class="team-role" data-lang="en">Assistant Professor of Regional and Urban Economics — Cedeplar/FACE/UFMG</p>
          <p class="team-lattes"><a href="http://lattes.cnpq.br/1814079278350942" target="_blank" rel="noopener">Lattes</a> · <a href="http://somos.ufmg.br/professor/joao-bosco-moura-tonucci-filho" target="_blank" rel="noopener">Perfil UFMG</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTATO -->
  <section class="section bg-light" id="contato">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;">
        <div>
          <div class="section-header left">
            <p class="eyebrow" data-lang="pt">Contato</p>
            <p class="eyebrow" data-lang="en">Contact</p>
            <h2 class="section-title" data-lang="pt">Contato</h2>
            <h2 class="section-title" data-lang="en">Get in touch</h2>
            <div class="divider"></div>
          </div>
          <div style="margin-bottom:1.5rem;">
            <p style="font-weight:700;color:var(--navy);margin-bottom:.25rem;" data-lang="pt">Endereço</p>
            <p style="font-weight:700;color:var(--navy);margin-bottom:.25rem;" data-lang="en">Address</p>
            <p style="color:var(--gray-700);" data-lang="pt">CERE — Faculdade de Ciências Econômicas | UFMG<br>Av. Antônio Carlos, 6627 — Pampulha<br>Belo Horizonte, MG — CEP 31270-901</p>
            <p style="color:var(--gray-700);" data-lang="en">CERE — Faculty of Economic Sciences | UFMG<br>Av. Antônio Carlos, 6627 — Pampulha<br>Belo Horizonte, MG — ZIP 31270-901</p>
          </div>
          <div style="margin-bottom:1.5rem;">
            <p style="font-weight:700;color:var(--navy);margin-bottom:.25rem;">E-mail</p>
            <p style="color:var(--gray-700);">renanpa@cedeplar.ufmg.br</p>
          </div>
          <div>
            <p style="font-weight:700;color:var(--navy);margin-bottom:.25rem;" data-lang="pt">Horário de atendimento</p>
            <p style="font-weight:700;color:var(--navy);margin-bottom:.25rem;" data-lang="en">Office hours</p>
            <p style="color:var(--gray-700);" data-lang="pt">Segunda a sexta: 09h–17h</p>
            <p style="color:var(--gray-700);" data-lang="en">Monday to Friday: 9am–5pm</p>
          </div>
        </div>
        <div>
          <form>
            <div class="form-row cols-2">
              <div class="form-group">
                <label data-lang="pt">Nome</label>
                <label data-lang="en">Name</label>
                <input type="text" class="form-control" placeholder="">
              </div>
              <div class="form-group">
                <label>E-mail</label>
                <input type="email" class="form-control" placeholder="">
              </div>
            </div>
            <div class="form-group mt-2">
              <label data-lang="pt">Assunto</label>
              <label data-lang="en">Subject</label>
              <input type="text" class="form-control" placeholder="">
            </div>
            <div class="form-group mt-2">
              <label data-lang="pt">Mensagem</label>
              <label data-lang="en">Message</label>
              <textarea class="form-control"></textarea>
            </div>
            <button type="submit" class="btn btn-primary mt-3" data-lang="pt">Enviar mensagem</button>
            <button type="submit" class="btn btn-primary mt-3" data-lang="en">Send message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer brand="full">
    <div class="footer-col">
      <h4 data-lang="pt">Sobre nós</h4><h4 data-lang="en">About us</h4>
      <ul>
        <li><a href="#missao"><span data-lang="pt">Missão</span><span data-lang="en">Mission</span></a></li>
        <li><a href="#pessoas"><span data-lang="pt">Pessoas</span><span data-lang="en">People</span></a></li>
        <li><a href="#contato"><span data-lang="pt">Contato</span><span data-lang="en">Contact</span></a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4 data-lang="pt">Educação & Pesquisa</h4><h4 data-lang="en">Education & Research</h4>
      <ul>
        <li><a href="/educacao/#graduacao"><span data-lang="pt">Graduação</span><span data-lang="en">Undergraduate</span></a></li>
        <li><a href="/educacao/#formacao-capacitacao"><span data-lang="pt">Formação e capacitação</span><span data-lang="en">Training and capacity-building</span></a></li>
        <li><a href="/pesquisa/#publicacoes"><span data-lang="pt">Publicações</span><span data-lang="en">Publications</span></a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4 data-lang="pt">Links úteis</h4><h4 data-lang="en">Useful links</h4>
      <ul>
        <li><a href="/dados/"><span data-lang="pt">Dados de mercado</span><span data-lang="en">Market data</span></a></li>
        <li><a href="/estudantes/#finance-club">UFMG Finance Club</a></li>
        <li><a href="/estudantes/#ucj">UFMG Consultoria Júnior (UCJ)</a></li>
        <li><a href="/parcerias/"><span data-lang="pt">Parcerias</span><span data-lang="en">Partnerships</span></a></li>
        <li><a href="https://face.ufmg.br" target="_blank" rel="noopener">FACE · UFMG</a></li>
      </ul>
    </div>
  </Footer>

</BaseLayout>
